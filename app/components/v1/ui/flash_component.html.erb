<div data-controller="flash"
     data-flash-delay-value="<%= @delay %>"
     class="flash <%= flash_class %> pointer-events-auto w-80 max-w-[calc(100vw-2rem)]">

  <span class="flex-1"><%= @message %></span>

  <button data-action="click->flash#dismiss"
          aria-label="Fermer"
          class="shrink-0 opacity-50 hover:opacity-100 transition-opacity -mr-1">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
</div>
