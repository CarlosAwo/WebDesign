<div>
	<% if @label %>
		<label class="block text-xs font-medium text-neutral-700 mb-1.5"> <%= @label %> 
			<% if @required %>
			  <span class="text-red-500">*</span>
			<% end %>
		</label>
	<% end %>
	<%= render "V1::Form::Elements::#{@field_type.to_s.classify}FieldComponent".constantize.new(form: @form, field_name: @field_name, metadata: @metadata, required: @required, placeholder: @placeholder, readonly: @readonly) %>
</div>	
