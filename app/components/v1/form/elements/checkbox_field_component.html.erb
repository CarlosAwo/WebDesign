<label class="inline-flex items-start gap-3 cursor-pointer select-none group">
  <%= @form.check_box @field_name,
        { required:        @required,
          checked_value:   @checked_value,
          unchecked_value: @unchecked_value,
          class: "form-checkbox mt-0.5 #{form_input_error if has_error?}" },
        @checked_value,
        @unchecked_value %>

  <span class="flex flex-col">
    <% if @placeholder.present? %>
      <span class="text-sm text-neutral-800"><%= @placeholder %></span>
    <% end %>
    <% if @description.present? %>
      <span class="text-xs text-neutral-400 mt-0.5"><%= @description %></span>
    <% end %>
  </span>
</label>

<% if has_error? %>
  <p class="<%= form_input_error_message %> mt-1"><%= error_message %></p>
<% end %>
