<div data-controller="nested-form"
     data-nested-form-max-value="<%= @max %>"
     class="space-y-3">

  <%# ── Enregistrements existants ── %>
  <div data-nested-form-target="container" class="space-y-3">
    <% if object_form? %>
      <%= @form.fields_for @association do |nested_form| %>
        <div class="nestedRecord relative rounded-lg border border-neutral-200 bg-white p-4">

          <% @fields.each do |field_name, field_settings| %>
            <%= render V1::Form::Blocks::FieldComponent.new(
              form:        nested_form,
              field_type:  field_settings[:type],
              label:       field_settings[:label],
              field_name:  field_name,
              placeholder: field_settings[:placeholder],
              metadata:    field_settings.fetch(:options, {})
            ) %>
          <% end %>

          <% if nested_form.object.persisted? %>
            <%= nested_form.hidden_field :id %>
          <% end %>

          <div class="mt-3 flex justify-end">
            <label class="inline-flex items-center gap-1.5 text-xs text-neutral-400 hover:text-danger-600 cursor-pointer transition-colors">
              <%= nested_form.check_box :_destroy,
                    class: "hidden",
                    data: { action: "change->nested-form#removeRecord" } %>
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/>
              </svg>
              <%= @remove_label %>
            </label>
          </div>

        </div>
      <% end %>
    <% end %>
  </div>

  <%# ── Bouton Ajouter (has_many uniquement) ── %>
  <% if has_many_association? && !@readonly %>
    <button type="button"
            data-action="click->nested-form#addNewRecord"
            data-nested-form-target="addButton"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors <%= "hidden" if max_reached? %>">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14"/>
      </svg>
      <%= @add_label %>
    </button>
  <% end %>

  <%# ── Template pour les nouveaux enregistrements ── %>
  <%# Utilisé par "script type=text/html" : Rails rend le HTML côté serveur,
      le JS lit .textContent, remplace NEW_RECORD par un timestamp, puis DOMParser insère dans le DOM ── %>
  <% if !@readonly %>
    <script type="text/html" data-nested-form-target="newRecordTemplate">
      <% if has_many_association? %>
        <%= @form.fields_for "#{@association}_attributes", @model.new, index: "NEW_RECORD" do |nested_form| %>
          <div class="nestedRecord relative rounded-lg border border-neutral-200 bg-white p-4">

            <% @fields.each do |field_name, field_settings| %>
              <%= render V1::Form::Blocks::FieldComponent.new(
                form:        nested_form,
                field_type:  field_settings[:type],
                label:       field_settings[:label],
                field_name:  field_name,
                placeholder: field_settings[:placeholder],
                metadata:    field_settings.fetch(:options, {})
              ) %>
            <% end %>

            <div class="mt-3 flex justify-end">
              <label class="inline-flex items-center gap-1.5 text-xs text-neutral-400 hover:text-danger-600 cursor-pointer transition-colors">
                <%= nested_form.check_box :_destroy,
                      class: "hidden",
                      data: { action: "change->nested-form#removeRecord" } %>
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/>
                </svg>
                <%= @remove_label %>
              </label>
            </div>

          </div>
        <% end %>
      <% elsif has_one_association? %>
        <%= @form.fields_for "#{@association}_attributes", @model.new do |nested_form| %>
          <div class="nestedRecord relative rounded-lg border border-neutral-200 bg-white p-4">

            <% @fields.each do |field_name, field_settings| %>
              <%= render V1::Form::Blocks::FieldComponent.new(
                form:        nested_form,
                field_type:  field_settings[:type],
                label:       field_settings[:label],
                field_name:  field_name,
                placeholder: field_settings[:placeholder],
                metadata:    field_settings.fetch(:options, {})
              ) %>
            <% end %>

          </div>
        <% end %>
      <% end %>
    </script>
  <% end %>

</div>
