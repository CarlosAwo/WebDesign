<div class="flex items-center gap-3">
  <%= @form.color_field @field_name,
        value:   @value || "#168249",
        class:   "h-10 w-16 cursor-pointer rounded-lg border border-neutral-300 p-1 bg-white
                  focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-0
                  #{'border-danger-500' if has_error?}" %>

  <span class="text-sm text-neutral-500"><%= @placeholder || "Choisir une couleur" %></span>
</div>

<% if has_error? %>
  <p class="form-input-error-message mt-1"><%= error_message %></p>
<% end %>
