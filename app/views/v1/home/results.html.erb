<div class="mx-auto max-w-5xl px-6 py-10">
  <header class="mb-8">
    <p class="mb-2 text-sm uppercase tracking-[0.24em] text-slate-500">V1 / Page de résultats</p>
    <h1 class="text-4xl font-semibold tracking-tight text-slate-900">Résultats du formulaire</h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">Les valeurs transmises par l’utilisateur sont affichées ci-dessous.</p>
  </header>

  <div class="space-y-6">
    <div class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
      <% if @values.values.any?(&:present?) %>
        <dl class="grid gap-6 sm:grid-cols-2">
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
            <dt class="text-sm font-semibold text-slate-600">Design system sélectionné</dt>
            <dd class="mt-2 text-lg text-slate-900"><%= @values[:selected_option].presence || "Aucune sélection" %></dd>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
            <dt class="text-sm font-semibold text-slate-600">Date</dt>
            <dd class="mt-2 text-lg text-slate-900"><%= @values[:selected_date].presence || "Non fournie" %></dd>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
            <dt class="text-sm font-semibold text-slate-600">Date de début</dt>
            <dd class="mt-2 text-lg text-slate-900"><%= @values[:range_start].presence || "Non fournie" %></dd>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
            <dt class="text-sm font-semibold text-slate-600">Date de fin</dt>
            <dd class="mt-2 text-lg text-slate-900"><%= @values[:range_end].presence || "Non fournie" %></dd>
          </div>
        </dl>

        <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-5">
          <dt class="text-sm font-semibold text-slate-600">Notes supplémentaires</dt>
          <dd class="mt-2 whitespace-pre-wrap text-base text-slate-900"><%= @values[:remarks].presence || "Aucune note" %></dd>
        </div>
      <% else %>
        <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 text-center">
          <p class="text-lg font-semibold text-slate-900">Aucune donnée reçue.</p>
          <p class="mt-2 text-sm text-slate-600">Retournez à la page d’exemples pour tester les composants.</p>
        </div>
      <% end %>
    </div>

    <div class="flex justify-between gap-4">
      <%= link_to "Retour aux exemples", v1_root_path, class: "inline-flex items-center rounded-full border border-slate-300 bg-slate-50 px-5 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-100" %>
      <%= link_to "Tester à nouveau", v1_root_path, class: "inline-flex items-center rounded-full bg-primary-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-700" %>
    </div>
  </div>
</div>
