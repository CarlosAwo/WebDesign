<div class="mx-auto max-w-5xl px-6 py-10">
  <header class="mb-10">
    <p class="mb-2 text-sm uppercase tracking-[0.24em] text-slate-500">V1 / Form elements</p>
    <h1 class="text-4xl font-semibold tracking-tight text-slate-900">Catalogue des composants</h1>
    <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">Un use case par variation d'options, organisé par élément de formulaire.</p>
  </header>

  <%= form_with url: v1_results_path, method: :get, local: true do |form| %>

    <%# ── 1. text_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">text_field</h2>
        <p class="text-xs font-mono text-slate-400">placeholder · required · readonly</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="grid gap-5 sm:grid-cols-3">
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :text,
            label: "Nom complet",
            field_name: :full_name,
            placeholder: "Jean Dupont"
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :text,
            label: "Nom de l'entreprise",
            field_name: :company_name,
            placeholder: "Acme Corp",
            required: true
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :text,
            label: "Identifiant système",
            field_name: :system_id,
            placeholder: "USR-00123",
            readonly: true
          ) %>
        </div>
      </div>
    </section>

    <%# ── 2. email_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">email_field</h2>
        <p class="text-xs font-mono text-slate-400">placeholder · required · readonly</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="grid gap-5 sm:grid-cols-3">
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :email,
            label: "Email de contact",
            field_name: :contact_email
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :email,
            label: "Email principal",
            field_name: :main_email,
            required: true
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :email,
            label: "Email vérifié",
            field_name: :verified_email,
            placeholder: "carlos@example.com",
            readonly: true
          ) %>
        </div>
      </div>
    </section>

    <%# ── 3. phone_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">phone_field</h2>
        <p class="text-xs font-mono text-slate-400">placeholder · required · readonly</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="grid gap-5 sm:grid-cols-3">
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :phone,
            label: "Numéro principal",
            field_name: :phone_main
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :phone,
            label: "Numéro d'urgence",
            field_name: :phone_emergency,
            required: true
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :phone,
            label: "Numéro de bureau",
            field_name: :phone_office,
            placeholder: "+33 1 23 45 67 89",
            readonly: true
          ) %>
        </div>
      </div>
    </section>

    <%# ── 4. password_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">password_field</h2>
        <p class="text-xs font-mono text-slate-400">placeholder · required · readonly · metadata[:toggle] · metadata[:timeout]</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="grid gap-5 sm:grid-cols-2">
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :password,
            label: "Mot de passe",
            field_name: :password,
            required: true
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :password,
            label: "Confirmation (toggle: true, timeout: 2s)",
            field_name: :password_confirm,
            required: true,
            metadata: { toggle: true, timeout: 2 }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :password,
            label: "Code PIN (toggle: false)",
            field_name: :pin,
            placeholder: "••••",
            metadata: { toggle: false }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :password,
            label: "Clé API (readonly)",
            field_name: :api_key,
            placeholder: "sk-••••••••••••••••••••",
            readonly: true
          ) %>
        </div>
      </div>
    </section>

    <%# ── 5. select_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">select_field</h2>
        <p class="text-xs font-mono text-slate-400">placeholder · required · readonly · metadata[:options] · metadata[:search]</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="grid gap-5 sm:grid-cols-2">
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :select,
            label: "Pays de résidence (search: true)",
            field_name: :country,
            placeholder: "Sélectionner un pays",
            metadata: { options: @country_options, search: true }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :select,
            label: "Profession (search: false)",
            field_name: :occupation,
            placeholder: "Sélectionner une profession",
            metadata: { options: @occupation_options, search: false }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :select,
            label: "Langue préférée (required)",
            field_name: :language,
            placeholder: "Choisir une langue",
            required: true,
            metadata: {
              options: [["Français", "fr"], ["English", "en"], ["Español", "es"], ["Deutsch", "de"]],
              search: false
            }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :select,
            label: "Rôle (readonly)",
            field_name: :role,
            placeholder: "Administrateur",
            readonly: true,
            metadata: {
              options: [["Administrateur", "admin"], ["Éditeur", "editor"], ["Visiteur", "viewer"]],
              search: false
            }
          ) %>
        </div>
      </div>
    </section>

    <%# ── 6. radio_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">radio_field</h2>
        <p class="text-xs font-mono text-slate-400">required · metadata[:options] · metadata[:layout] (:horizontal / :vertical)</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6">
        <%= render V1::Form::Blocks::FieldComponent.new(
          form: form,
          field_type: :radio,
          label: "Civilité (layout: horizontal)",
          field_name: :civility,
          metadata: {
            options: [["Monsieur", "mr"], ["Madame", "mrs"], ["Non précisé", "other"]],
            layout: :horizontal
          }
        ) %>
        <%= render V1::Form::Blocks::FieldComponent.new(
          form: form,
          field_type: :radio,
          label: "Type de compte (layout: vertical)",
          field_name: :account_type,
          metadata: {
            options: [["Particulier", "personal"], ["Professionnel", "business"], ["Association", "nonprofit"]],
            layout: :vertical
          }
        ) %>
        <%= render V1::Form::Blocks::FieldComponent.new(
          form: form,
          field_type: :radio,
          label: "Abonnement (required + horizontal)",
          field_name: :plan,
          required: true,
          metadata: {
            options: [["Gratuit", "free"], ["Pro", "pro"], ["Entreprise", "enterprise"]],
            layout: :horizontal
          }
        ) %>
      </div>
    </section>

    <%# ── 7. date_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">date_field</h2>
        <p class="text-xs font-mono text-slate-400">required · metadata[:mode] (single / range) · metadata[:time] · metadata[:seconds]</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="grid gap-5 sm:grid-cols-3">
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :date,
            label: "Date de naissance (single)",
            field_name: :birth_date,
            metadata: { mode: "single", time: false }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :date,
            label: "Rendez-vous (single + time)",
            field_name: :appointment,
            metadata: { mode: "single", time: true }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :date,
            label: "Horodatage (single + time + seconds)",
            field_name: :precise_timestamp,
            metadata: { mode: "single", time: true, seconds: true }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :date,
            label: "Disponibilité (range)",
            field_name: :availability,
            metadata: { mode: "range", time: false }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :date,
            label: "Plage horaire (range + time)",
            field_name: :time_slot,
            metadata: { mode: "range", time: true }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :date,
            label: "Entrée en fonction (required)",
            field_name: :start_date,
            required: true,
            metadata: { mode: "single", time: false }
          ) %>
        </div>
      </div>
    </section>

    <%# ── 8. amount_input_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">amount_input_field</h2>
        <p class="text-xs font-mono text-slate-400">placeholder · required · readonly · metadata[:currency] · metadata[:currency_position] · metadata[:hint]</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="grid gap-5 sm:grid-cols-3">
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :amount_input,
            label: "Budget mensuel (currency_position: right)",
            field_name: :monthly_budget,
            placeholder: "0",
            metadata: { currency: "€", currency_position: :right, hint: "Montant en euros" }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :amount_input,
            label: "Salaire annuel (currency_position: left)",
            field_name: :annual_salary,
            placeholder: "0",
            metadata: { currency: "$", currency_position: :left, hint: "Salaire brut annuel" }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :amount_input,
            label: "Quantité (sans currency)",
            field_name: :quantity,
            placeholder: "0"
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :amount_input,
            label: "Prix de vente (required)",
            field_name: :sale_price,
            placeholder: "0",
            required: true,
            metadata: { currency: "€", currency_position: :right, hint: "TVA incluse" }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :amount_input,
            label: "Total calculé (readonly)",
            field_name: :computed_total,
            placeholder: "1 250",
            readonly: true,
            metadata: { currency: "€", currency_position: :right, hint: "Calculé automatiquement" }
          ) %>
        </div>
      </div>
    </section>

    <%# ── 9. color_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">color_field</h2>
        <p class="text-xs font-mono text-slate-400">placeholder · required · readonly</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="grid gap-5 sm:grid-cols-3">
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :color,
            label: "Couleur de thème",
            field_name: :theme_color,
            placeholder: "Choisir votre couleur"
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :color,
            label: "Couleur de la marque (required)",
            field_name: :brand_color,
            placeholder: "Couleur obligatoire",
            required: true
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :color,
            label: "Couleur système (readonly)",
            field_name: :system_color,
            placeholder: "#168249",
            readonly: true
          ) %>
        </div>
      </div>
    </section>

    <%# ── 10. file_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">file_field</h2>
        <p class="text-xs font-mono text-slate-400">placeholder · required · metadata[:hint] · metadata[:accept] · metadata[:upload_text]</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-5">
        <%= render V1::Form::Blocks::FieldComponent.new(
          form: form,
          field_type: :file,
          label: "Photo de profil (accept: image/*)",
          field_name: :avatar,
          placeholder: "Importer une photo",
          metadata: {
            hint: "JPG, PNG ou GIF · max 5 Mo",
            accept: "image/*",
            upload_text: "Parcourir"
          }
        ) %>
        <%= render V1::Form::Blocks::FieldComponent.new(
          form: form,
          field_type: :file,
          label: "Curriculum Vitae (accept: PDF, required)",
          field_name: :cv_file,
          placeholder: "Importer votre CV",
          required: true,
          metadata: {
            hint: "PDF uniquement · max 2 Mo",
            accept: "application/pdf",
            upload_text: "Choisir un PDF"
          }
        ) %>
        <%= render V1::Form::Blocks::FieldComponent.new(
          form: form,
          field_type: :file,
          label: "Pièce jointe (accept: tous types)",
          field_name: :attachment,
          placeholder: "Importer un fichier",
          metadata: {
            hint: "Tout type de fichier · max 10 Mo",
            accept: "",
            upload_text: "Choisir"
          }
        ) %>
      </div>
    </section>

    <%# ── 11. textarea_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">textarea_field</h2>
        <p class="text-xs font-mono text-slate-400">placeholder · required · readonly · metadata[:rows] · metadata[:hint]</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="grid gap-5 sm:grid-cols-2">
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :textarea,
            label: "Commentaire court (rows: 3)",
            field_name: :short_comment,
            placeholder: "Votre commentaire…",
            metadata: { rows: 3 }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :textarea,
            label: "Biographie (rows: 6 + hint)",
            field_name: :biography,
            placeholder: "Parlez-nous de vous…",
            metadata: { rows: 6, hint: "Maximum 500 caractères" }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :textarea,
            label: "Description du projet (required + hint)",
            field_name: :project_description,
            placeholder: "Décrivez votre projet en détail…",
            required: true,
            metadata: { rows: 4, hint: "Min. 100 caractères" }
          ) %>
          <%= render V1::Form::Blocks::FieldComponent.new(
            form: form,
            field_type: :textarea,
            label: "Conditions générales (readonly)",
            field_name: :terms_text,
            placeholder: "Article 1 — En acceptant ces conditions…",
            readonly: true,
            metadata: { rows: 4 }
          ) %>
        </div>
      </div>
    </section>

    <%# ── 12. checkbox_field ── %>
    <section class="mb-14">
      <div class="mb-4">
        <h2 class="text-lg font-semibold text-slate-900">checkbox_field</h2>
        <p class="text-xs font-mono text-slate-400">placeholder · required · metadata[:description] · metadata[:checked_value] · metadata[:unchecked_value]</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-4">
        <%= render V1::Form::Blocks::FieldComponent.new(
          form: form,
          field_type: :checkbox,
          label: nil,
          field_name: :marketing_emails,
          placeholder: "Recevoir les actualités par email"
        ) %>
        <%= render V1::Form::Blocks::FieldComponent.new(
          form: form,
          field_type: :checkbox,
          label: nil,
          field_name: :terms,
          placeholder: "J'accepte les conditions générales d'utilisation",
          metadata: { description: "En cochant cette case, vous acceptez notre politique de confidentialité." }
        ) %>
        <%= render V1::Form::Blocks::FieldComponent.new(
          form: form,
          field_type: :checkbox,
          label: nil,
          field_name: :age_verified,
          placeholder: "Je certifie avoir plus de 18 ans",
          required: true,
          metadata: { description: "Confirmation requise pour accéder au service." }
        ) %>
        <%= render V1::Form::Blocks::FieldComponent.new(
          form: form,
          field_type: :checkbox,
          label: nil,
          field_name: :notifications_enabled,
          placeholder: "Activer les notifications push",
          metadata: {
            checked_value: "enabled",
            unchecked_value: "disabled",
            description: "checked_value: 'enabled' · unchecked_value: 'disabled'"
          }
        ) %>
      </div>
    </section>

    <div class="flex justify-end">
      <%= form.submit "Enregistrer le profil", class: "btn btn-primary btn-lg" %>
    </div>

  <% end %>

  <%# ── 13. card_component ── %>
  <section class="mb-14">
    <div class="mb-4">
      <h2 class="text-lg font-semibold text-slate-900">card_component</h2>
      <p class="text-xs font-mono text-slate-400">image_src · title · href · date · description · content slot</p>
    </div>
    <div class="grid gap-6 sm:grid-cols-3">

      <%= render V1::Ui::CardComponent.new(
        image_src:   "https://images.unsplash.com/photo-1524758631624-e2822e304c36?auto=format&fit=crop&q=80&w=800",
        image_alt:   "Interior design",
        date:        "10th Oct 2022",
        datetime:    "2022-10-10",
        title:       "How to position your furniture for positivity",
        href:        "#",
        description: "Lorem ipsum dolor sit amet, consectetur adipisicing elit. Recusandae dolores, possimus pariatur animi temporibus nesciunt praesentium dolore sed nulla ipsum eveniet corporis quidem, mollitia itaque minus soluta."
      ) %>

      <%= render V1::Ui::CardComponent.new(
        image_src:   "https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85?auto=format&fit=crop&q=80&w=800",
        image_alt:   "City at night",
        date:        "3rd Mar 2023",
        datetime:    "2023-03-03",
        title:       "The art of minimalist living in urban spaces",
        href:        "#",
        description: "Pariatur animi temporibus nesciunt praesentium dolore sed nulla ipsum eveniet corporis quidem, mollitia itaque minus soluta, voluptates neque explicabo tempora nisi culpa."
      ) %>

      <%# Sans image, avec content slot %>
      <%= render V1::Ui::CardComponent.new(
        date:        "15th Jan 2024",
        datetime:    "2024-01-15",
        title:       "Card sans image avec footer custom",
        description: "Un exemple de card sans image mais avec un slot de contenu personnalisé en bas."
      ) do %>
        <a href="#" class="btn btn-outline btn-sm">Lire l'article</a>
      <% end %>

    </div>
  </section>

  <%# ── 14. avatar_component ── %>
  <section class="mb-14">
    <div class="mb-4">
      <h2 class="text-lg font-semibold text-slate-900">avatar_component</h2>
      <p class="text-xs font-mono text-slate-400">src · initials · size · status · shape</p>
    </div>

    <%# Tailles %>
    <div class="mb-3">
      <p class="mb-2 text-xs font-medium text-slate-400 uppercase tracking-widest">Tailles</p>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-wrap gap-4 items-end">
        <%= render V1::Ui::AvatarComponent.new(initials: "CA", size: :xs) %>
        <%= render V1::Ui::AvatarComponent.new(initials: "CA", size: :sm) %>
        <%= render V1::Ui::AvatarComponent.new(initials: "CA", size: :md) %>
        <%= render V1::Ui::AvatarComponent.new(initials: "CA", size: :lg) %>
        <%= render V1::Ui::AvatarComponent.new(initials: "CA", size: :xl) %>
      </div>
    </div>

    <%# Image vs initiales %>
    <div class="mb-3">
      <p class="mb-2 text-xs font-medium text-slate-400 uppercase tracking-widest">Image & initiales</p>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-wrap gap-4 items-center">
        <%= render V1::Ui::AvatarComponent.new(src: "https://i.pravatar.cc/150?u=carlos", initials: "CA", size: :lg) %>
        <%= render V1::Ui::AvatarComponent.new(src: "https://i.pravatar.cc/150?u=alice",  initials: "AL", size: :lg) %>
        <%= render V1::Ui::AvatarComponent.new(initials: "CA", size: :lg) %>
        <%= render V1::Ui::AvatarComponent.new(initials: "AL", size: :lg) %>
        <%= render V1::Ui::AvatarComponent.new(initials: "JD", size: :lg) %>
        <%= render V1::Ui::AvatarComponent.new(initials: "MX", size: :lg) %>
        <%= render V1::Ui::AvatarComponent.new(size: :lg) %>
      </div>
    </div>

    <%# Statuts %>
    <div class="mb-3">
      <p class="mb-2 text-xs font-medium text-slate-400 uppercase tracking-widest">Statuts</p>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-wrap gap-6 items-center">
        <div class="flex flex-col items-center gap-2">
          <%= render V1::Ui::AvatarComponent.new(initials: "CA", size: :md, status: :online) %>
          <span class="text-xs text-slate-400">online</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <%= render V1::Ui::AvatarComponent.new(initials: "AL", size: :md, status: :away) %>
          <span class="text-xs text-slate-400">away</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <%= render V1::Ui::AvatarComponent.new(initials: "JD", size: :md, status: :busy) %>
          <span class="text-xs text-slate-400">busy</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <%= render V1::Ui::AvatarComponent.new(initials: "MX", size: :md, status: :offline) %>
          <span class="text-xs text-slate-400">offline</span>
        </div>
      </div>
    </div>

    <%# Forme %>
    <div class="mb-3">
      <p class="mb-2 text-xs font-medium text-slate-400 uppercase tracking-widest">Formes</p>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-wrap gap-6 items-center">
        <div class="flex flex-col items-center gap-2">
          <%= render V1::Ui::AvatarComponent.new(initials: "CA", size: :lg, shape: :circle) %>
          <span class="text-xs text-slate-400">circle</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <%= render V1::Ui::AvatarComponent.new(initials: "CA", size: :lg, shape: :rounded) %>
          <span class="text-xs text-slate-400">rounded</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <%= render V1::Ui::AvatarComponent.new(src: "https://i.pravatar.cc/150?u=carlos", initials: "CA", size: :lg, shape: :circle, status: :online) %>
          <span class="text-xs text-slate-400">circle + status</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <%= render V1::Ui::AvatarComponent.new(src: "https://i.pravatar.cc/150?u=alice", initials: "AL", size: :lg, shape: :rounded, status: :away) %>
          <span class="text-xs text-slate-400">rounded + status</span>
        </div>
      </div>
    </div>
  </section>

  <%# ── 14. buttons ── %>
  <section class="mb-14">
    <div class="mb-4">
      <h2 class="text-lg font-semibold text-slate-900">buttons</h2>
      <p class="text-xs font-mono text-slate-400">.btn · .btn-{primary|secondary|outline|danger|ghost} · .btn-{sm|lg} · .btn-disabled · .btn-full</p>
    </div>

    <%# Variantes %>
    <div class="mb-3">
      <p class="mb-2 text-xs font-medium text-slate-400 uppercase tracking-widest">Variantes</p>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-wrap gap-3 items-center">
        <button class="btn btn-primary">Primary</button>
        <button class="btn btn-secondary">Secondary</button>
        <button class="btn btn-outline">Outline</button>
        <button class="btn btn-danger">Danger</button>
        <button class="btn btn-ghost">Ghost</button>
      </div>
    </div>

    <%# Tailles %>
    <div class="mb-3">
      <p class="mb-2 text-xs font-medium text-slate-400 uppercase tracking-widest">Tailles</p>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-wrap gap-3 items-center">
        <button class="btn btn-primary btn-sm">Small</button>
        <button class="btn btn-primary">Medium</button>
        <button class="btn btn-primary btn-lg">Large</button>
      </div>
    </div>

    <%# Avec icônes %>
    <div class="mb-3">
      <p class="mb-2 text-xs font-medium text-slate-400 uppercase tracking-widest">Avec icônes</p>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-wrap gap-3 items-center">

        <button class="btn btn-primary">
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          Enregistrer
        </button>

        <button class="btn btn-outline">
          Télécharger
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/>
          </svg>
        </button>

        <button class="btn btn-danger">
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/>
          </svg>
          Supprimer
        </button>

        <%# Icône seule %>
        <button class="btn btn-ghost px-2.5">
          <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14"/>
          </svg>
        </button>

      </div>
    </div>

    <%# États %>
    <div class="mb-3">
      <p class="mb-2 text-xs font-medium text-slate-400 uppercase tracking-widest">États</p>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-wrap gap-3 items-center">
        <button class="btn btn-primary"           disabled>Disabled primary</button>
        <button class="btn btn-secondary"         disabled>Disabled secondary</button>
        <button class="btn btn-outline btn-disabled">Disabled outline (lien)</button>
      </div>
    </div>

    <%# Liens + pleine largeur %>
    <div class="mb-3">
      <p class="mb-2 text-xs font-medium text-slate-400 uppercase tracking-widest">Liens & pleine largeur</p>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-3">
        <div class="flex gap-3">
          <a href="#" class="btn btn-primary">Lien primary</a>
          <a href="#" class="btn btn-outline">Lien outline</a>
        </div>
        <button class="btn btn-primary btn-full">Pleine largeur primary</button>
        <button class="btn btn-outline btn-full">Pleine largeur outline</button>
      </div>
    </div>
  </section>

  <%# ── 14. lightbox_component ── %>
  <section class="mb-14">
    <div class="mb-4">
      <h2 class="text-lg font-semibold text-slate-900">lightbox_component</h2>
      <p class="text-xs font-mono text-slate-400">src · alt · img_class — survol pour agrandir, clic pour ouvrir, Échap / ✕ pour fermer</p>
    </div>
    <div class="grid gap-5 sm:grid-cols-3">

      <%= render V1::Ui::LightboxComponent.new(
        src: "https://picsum.photos/seed/forest/800/600",
        alt: "Forêt",
        img_class: "h-48"
      ) %>

      <%= render V1::Ui::LightboxComponent.new(
        src: "https://picsum.photos/seed/city/800/600",
        alt: "Ville",
        img_class: "h-48"
      ) %>

      <%= render V1::Ui::LightboxComponent.new(
        src: "https://picsum.photos/seed/mountain/800/600",
        alt: "Montagne",
        img_class: "h-48"
      ) %>

    </div>

    <%# Raw HTML usage example %>
    <div class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 p-5">
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-slate-400">Usage HTML brut (sans composant)</p>
      <div class="grid gap-5 sm:grid-cols-2">

        <div data-controller="lightbox"
             data-lightbox-url-value="https://picsum.photos/seed/ocean/800/600">
          <div data-lightbox-target="container" class="lightbox-wrapper overflow-hidden rounded-xl">
            <img data-lightbox-target="image"
                 src="https://picsum.photos/seed/ocean/800/600"
                 alt="Océan"
                 class="w-full h-40 object-cover" />
          </div>
        </div>

        <div data-controller="lightbox"
             data-lightbox-url-value="https://picsum.photos/seed/desert/800/600">
          <div data-lightbox-target="container" class="lightbox-wrapper overflow-hidden rounded-xl">
            <img data-lightbox-target="image"
                 src="https://picsum.photos/seed/desert/800/600"
                 alt="Désert"
                 class="w-full h-40 object-cover" />
          </div>
        </div>

      </div>
    </div>
  </section>

</div>
