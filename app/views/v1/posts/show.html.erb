<div class="mx-auto max-w-3xl px-6 py-10">

  <%# ── Header ── %>
  <div class="mb-8 flex items-start justify-between">
    <div>
      <p class="mb-1 text-sm uppercase tracking-[0.24em] text-slate-500">V1 / Posts</p>
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900"><%= @post.title %></h1>
      <div class="mt-2 flex items-center gap-3">
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
          <%= case @post.status
              when 'published' then 'bg-primary-50 text-primary-700'
              when 'draft'     then 'bg-amber-50 text-amber-700'
              else                  'bg-neutral-100 text-neutral-500'
              end %>">
          <%= @post.status&.humanize || "—" %>
        </span>
        <% if @post.published_at %>
          <span class="text-xs text-slate-400">Publié le <%= @post.published_at.strftime("%d %B %Y à %H:%M") %></span>
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-2 mt-1">
      <%= link_to "Modifier", edit_v1_post_path(@post), class: "btn btn-outline btn-sm" %>
      <%= link_to "← Liste", v1_posts_path, class: "btn btn-ghost btn-sm" %>
    </div>
  </div>

  <%# ── Description ── %>
  <% if @post.description.present? %>
    <div class="mb-8 rounded-xl border border-neutral-200 bg-white p-6">
      <p class="text-sm text-neutral-700 leading-relaxed"><%= @post.description %></p>
    </div>
  <% end %>

  <%# ── Commentaires ── %>
  <div class="rounded-xl border border-neutral-200 bg-white overflow-hidden">
    <div class="flex items-center justify-between border-b border-neutral-100 px-6 py-4">
      <h2 class="text-sm font-semibold text-neutral-700">
        Commentaires
        <span class="ml-1.5 inline-flex items-center justify-center rounded-full bg-neutral-100 px-2 py-0.5 text-xs font-medium text-neutral-500">
          <%= @post.comments.size %>
        </span>
      </h2>
      <%= link_to "Modifier les commentaires", edit_v1_post_path(@post), class: "text-xs text-primary-600 hover:text-primary-700 font-medium" %>
    </div>

    <% if @post.comments.empty? %>
      <p class="px-6 py-10 text-center text-sm text-slate-400">Aucun commentaire pour cet article.</p>
    <% else %>
      <ul class="divide-y divide-neutral-100">
        <% @post.comments.each do |comment| %>
          <li class="px-6 py-4">
            <div class="flex items-start gap-3">
              <%= render V1::Ui::AvatarComponent.new(
                initials: comment.author.to_s.split.map(&:first).first(2).join.upcase.presence || "?",
                size: :sm
              ) %>
              <div class="min-w-0 flex-1">
                <p class="text-xs font-semibold text-neutral-800"><%= comment.author.presence || "Anonyme" %></p>
                <p class="mt-0.5 text-sm text-neutral-600 leading-relaxed"><%= comment.content %></p>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

</div>
