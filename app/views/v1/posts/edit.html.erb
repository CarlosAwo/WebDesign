<div class="mx-auto max-w-3xl px-6 py-10">

  <div class="mb-8 flex items-start justify-between">
    <div>
      <p class="mb-1 text-sm uppercase tracking-[0.24em] text-slate-500">V1 / Posts</p>
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900">Modifier l'article</h1>
      <p class="mt-1 text-sm text-slate-400 truncate max-w-md"><%= @post.title %></p>
    </div>
    <%= link_to "← Retour", v1_posts_path, class: "text-sm text-slate-400 hover:text-slate-700 transition-colors mt-1" %>
  </div>

  <%= render "form", post: @post %>

</div>
